---
import Layout from "../layouts/Layout.astro";

const navLinks = [
  { href: "#o-szkole", label: "O nas" },
  { href: "#kursy", label: "Kursy" },
  { href: "#cennik", label: "Cennik" },
  { href: "#instruktorzy", label: "Instruktorzy" },
  { href: "#opinie", label: "Opinie" },
  { href: "#kontakt", label: "Kontakt" },
];

const stats = [
  { value: 94, suffix: "%", label: "zdawalność" },
  { value: 12, suffix: "+", label: "lat doświadczenia" },
  { value: 3200, suffix: "+", label: "absolwentów" },
  { value: 8, suffix: "", label: "instruktorów" },
];

const features = [
  { icon: "🚗", title: "Nowoczesna flota", desc: "Samochody rocznik 2022–2024, klimatyzacja, podwójne pedały bezpieczeństwa." },
  { icon: "📍", title: "Centrum Warszawy", desc: "Oddział przy ul. Marszałkowskiej — dojedziesz metrem, autobusem lub tramwajem." },
  { icon: "🗓️", title: "Elastyczne terminy", desc: "Jazdy rano, po południu i w weekendy. Dopasuj grafik do siebie." },
  { icon: "👨‍🏫", title: "Certyfikowani instruktorzy", desc: "Każdy instruktor z licencją MiR, przeszkolony w technikach motywacyjnych." },
  { icon: "📱", title: "Zapisy online", desc: "Formularz 24/7, potwierdzenie SMS i e-mail. Zero kolejek w biurze." },
  { icon: "🏆", title: "94% zdawalności", desc: "Powyżej średniej krajowej. Metodyka oparta na symulacjach egzaminu." },
];

const courses = [
  {
    id: "kat-b",
    tag: "Najpopularniejszy",
    icon: "🚗",
    title: "Kurs kat. B",
    subtitle: "Skrzynia manualna",
    desc: "Pełny kurs na prawo jazdy kategorii B. 30 godzin teorii + 30 godzin jazdy praktycznej. Przygotowanie do egzaminu w WORD.",
    details: ["30h teorii (online lub stacjonarnie)", "30h jazdy praktycznej", "Jazdy w mieście i na autostradzie", "2 x jazdy egzaminacyjne WORD", "Materiały do nauki w cenie"],
    price: "2 400",
    color: "blue",
  },
  {
    id: "automat",
    tag: "Szybciej i łatwiej",
    icon: "⚙️",
    title: "Kurs w automacie",
    subtitle: "Skrzynia automatyczna",
    desc: "Kurs na prawo jazdy kat. B na samochodzie z automatyczną skrzynią biegów. Idealne dla osób z tremą lub kontuzjami.",
    details: ["30h teorii (online lub stacjonarnie)", "30h jazdy na automacie", "Nowoczesny Toyota Yaris Cross", "Egzamin tylko na automacie", "Możliwość zmiany na manualny +500 zł"],
    price: "2 700",
    color: "yellow",
  },
  {
    id: "doszkalajace",
    tag: "Dla posiadaczy prawa jazdy",
    icon: "🔄",
    title: "Jazdy doszkalające",
    subtitle: "Dla istniejących kierowców",
    desc: "Odśwież umiejętności jazdy, wyeliminuj złe nawyki lub przygotuj się do jazdy po dłuższej przerwie.",
    details: ["Pakiet 5 jazd lub 10 jazd", "Ocena aktualnych umiejętności", "Jazda nocna lub autostradowa", "Parking i manewry", "Elastyczne terminy"],
    price: "od 200",
    color: "red",
  },
  {
    id: "intensywny",
    tag: "Ekspresowo",
    icon: "⚡",
    title: "Kurs intensywny",
    subtitle: "2–3 tygodnie",
    desc: "Cały kurs w błyskawicznym tempie. Teoria online w tydzień, jazdy codziennie rano. Dla zdecydowanych i zdyscyplinowanych.",
    details: ["Teoria online (platforma 24/7)", "Jazdy codziennie lub co 2 dni", "Indywidualny harmonogram", "Priorytetowy termin egzaminu", "Opieka mentora w cenie"],
    price: "2 900",
    color: "blue",
  },
];

const pricing = [
  { label: "Kurs kat. B (manualna)", price: "2 400 zł", note: "teoria + 30h jazd" },
  { label: "Kurs w automacie", price: "2 700 zł", note: "teoria + 30h jazd" },
  { label: "Kurs intensywny", price: "2 900 zł", note: "pełny + priorytet egz." },
  { label: "Pojedyncza jazda (60 min)", price: "150 zł", note: "po zdanym egzaminie" },
  { label: "Jazda doszkalająca — pakiet 5", price: "700 zł", note: "5 × 60 min" },
  { label: "Jazda doszkalająca — pakiet 10", price: "1 300 zł", note: "10 × 60 min, oszczędzasz 200 zł" },
  { label: "Teoria online (bez jazd)", price: "300 zł", note: "dostęp 90 dni" },
  { label: "Egzamin wewnętrzny", price: "gratis", note: "w cenie kursu" },
];

const instructors = [
  {
    name: "Marek Kowalski",
    title: "Instruktor senior",
    exp: "14 lat doświadczenia",
    spec: "Jazda w trudnych warunkach, manewr parkowania",
    img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=400&q=80",
    emoji: "👨‍💼",
  },
  {
    name: "Anna Wiśniewska",
    title: "Instruktorka",
    exp: "8 lat doświadczenia",
    spec: "Techniki obronne, kurs intensywny",
    img: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=400&q=80",
    emoji: "👩‍💼",
  },
  {
    name: "Piotr Nowak",
    title: "Instruktor",
    exp: "6 lat doświadczenia",
    spec: "Automat, jazda po autostradzie",
    img: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&w=400&q=80",
    emoji: "👨‍🔧",
  },
  {
    name: "Katarzyna Zając",
    title: "Instruktorka",
    exp: "5 lat doświadczenia",
    spec: "Kursanci z tremą, jazdy nocne",
    img: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=400&q=80",
    emoji: "👩‍🏫",
  },
];

const reviews = [
  {
    name: "Karolina M.",
    rating: 5,
    text: "Zdałam egzamin za pierwszym razem! Pani Anna była super cierpliwa i bardzo profesjonalna. Polecam OSK Start z czystym sumieniem 🚗",
    date: "Marzec 2025",
    course: "Kurs kat. B",
  },
  {
    name: "Damian W.",
    rating: 5,
    text: "Wybrałem kurs intensywny i w 3 tygodnie byłem po egzaminie. Wszystko sprawnie zorganizowane, instruktor Marek to prawdziwy pro.",
    date: "Luty 2025",
    course: "Kurs intensywny",
  },
  {
    name: "Zofia K.",
    rating: 5,
    text: "Miałam dużą tremę przed jazdą, ale Kasia (instruktorka) całkowicie ją rozwiała. Spokojna, konkretna, wytłumaczyła każdy manewr. Dziękuję!",
    date: "Kwiecień 2025",
    course: "Kurs w automacie",
  },
  {
    name: "Tomasz B.",
    rating: 5,
    text: "Cena konkurencyjna, biuro zawsze dostępne, terminy elastyczne. Sam polecałem już 3 osobom z pracy. Nie ma lepszej szkoły jazdy w centrum.",
    date: "Styczeń 2025",
    course: "Kurs kat. B",
  },
  {
    name: "Marta R.",
    rating: 5,
    text: "Wróciłam po 5 latach przerwy od jazdy. Jazdy doszkalające z panem Piotrem totalnie przywróciły mi pewność. Czuję się teraz bezpiecznie na drodze.",
    date: "Maj 2025",
    course: "Jazdy doszkalające",
  },
  {
    name: "Łukasz S.",
    rating: 4,
    text: "Dobra szkoła, profesjonalne podejście. Jedyna drobna uwaga to parking przy biurze — ale sala teorii super i platforma online naprawdę wygodna.",
    date: "Kwiecień 2025",
    course: "Kurs kat. B",
  },
];

const schedule = [
  { day: "Poniedziałek – Piątek", hours: "7:00 – 21:00" },
  { day: "Sobota", hours: "8:00 – 18:00" },
  { day: "Niedziela", hours: "9:00 – 15:00" },
];
---

<Layout>
  <!-- ═══════════════════════════════════════ NAV ═══════════════════════════════════════ -->
  <header id="nav" class="fixed left-0 right-0 z-50 transition-all duration-300" style="top: 2.25rem">
    <nav class="container mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2.5 group">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center font-display font-800 text-sm leading-none"
             style="background: var(--color-yellow); color: var(--color-dark);">
          L
        </div>
        <span class="font-display font-700 text-xl" style="color: var(--color-dark);">
          OSK <span style="color: var(--color-blue);">Start</span>
        </span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <li>
            <a href={link.href}
               class="px-4 py-2 rounded-lg text-sm font-medium font-body transition-all duration-200 hover:bg-blue-50"
               style="color: var(--color-dark-mid);">
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA + burger -->
      <div class="flex items-center gap-3">
        <a href="#zapisy"
           class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-display font-700 transition-all duration-200 hover:scale-105 hover:shadow-lg pulse-glow"
           style="background: var(--color-blue); color: #fff;">
          Zapisz się →
        </a>
        <button id="burger" class="lg:hidden p-2 rounded-lg" style="color: var(--color-dark);" aria-label="Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7h18M3 12h18M3 17h18" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t" style="background: rgba(255,255,255,0.98); border-color: var(--color-gray-light);">
      <div class="container mx-auto px-4 py-4 flex flex-col gap-1">
        {navLinks.map(link => (
          <a href={link.href}
             class="px-4 py-3 rounded-lg text-sm font-medium hover:bg-blue-50"
             style="color: var(--color-dark-mid);">
            {link.label}
          </a>
        ))}
        <a href="#zapisy"
           class="mt-2 px-4 py-3 rounded-xl text-sm font-display font-700 text-center"
           style="background: var(--color-blue); color: #fff;">
          Zapisz się →
        </a>
      </div>
    </div>
  </header>

  <!-- Scrolled nav style -->
  <style>
    #nav.scrolled {
      background: color-mix(in srgb, #ffffff 95%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--color-gray-light);
      box-shadow: 0 2px 20px rgba(21,32,58,0.08);
    }
  </style>

  <main>
    <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
    <section id="hero"
             class="relative min-h-screen flex flex-col justify-center overflow-hidden"
             style="background: var(--color-dark); padding-top: 8rem;">

      <!-- Background image -->
      <div class="absolute inset-0 z-0">
        <img
          src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=1920&q=80"
          alt="Droga z samochodem"
          class="w-full h-full object-cover opacity-30"
        />
        <div class="absolute inset-0"
             style="background: linear-gradient(135deg, rgba(21,32,58,0.95) 0%, rgba(29,78,216,0.6) 60%, rgba(21,32,58,0.85) 100%);"></div>
        <!-- Speed lines overlay -->
        <div class="absolute inset-0 opacity-10"
             style="background-image: repeating-linear-gradient(170deg, rgba(255,255,255,0.4) 0, rgba(255,255,255,0.4) 1px, transparent 1px, transparent 40px);"></div>
      </div>

      <!-- Road stripe top -->
      <div class="absolute top-0 left-0 right-0 z-10 road-stripe opacity-60"></div>

      <!-- Floating L badge -->
      <div class="float-badge absolute top-36 right-8 md:right-24 z-10 hidden md:flex">
        <div class="w-24 h-24 rounded-2xl flex items-center justify-center text-5xl font-display font-800 shadow-2xl border-4"
             style="background: var(--color-yellow); color: var(--color-dark); border-color: rgba(255,255,255,0.3); transform: rotate(-8deg);">
          L
        </div>
      </div>

      <!-- Hero content -->
      <div class="relative z-10 container mx-auto px-4 sm:px-6 py-16">
        <div class="max-w-3xl">
          <!-- Badge -->
          <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-display font-600 mb-6 tracking-wide uppercase"
               style="background: rgba(250,204,21,0.15); color: var(--color-yellow); border: 1px solid rgba(250,204,21,0.3);">
            🏆 Zdawalność 94% — powyżej średniej krajowej
          </div>

          <h1 class="reveal delay-1 font-display text-5xl sm:text-6xl lg:text-7xl font-800 leading-none mb-6"
              style="color: #fff;">
            Ruszaj z nami<br />
            <span style="color: var(--color-yellow);">na drogę</span><br />
            do sukcesu!
          </h1>

          <p class="reveal delay-2 text-lg sm:text-xl max-w-xl mb-8 leading-relaxed"
             style="color: rgba(255,255,255,0.75);">
            Nowoczesna szkoła jazdy w centrum Warszawy. Kurs kat. B, jazdy w automacie,
            intensywny kurs — Ty wybierasz tempo, my zadbamy o resztę.
          </p>

          <div class="reveal delay-3 flex flex-col sm:flex-row gap-4 mb-16">
            <a href="#zapisy"
               class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl text-base font-display font-700 transition-all duration-200 hover:scale-105 hover:shadow-2xl"
               style="background: var(--color-yellow); color: var(--color-dark);">
              🚀 Zapisz się na kurs
            </a>
            <a href="#kursy"
               class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl text-base font-display font-600 transition-all duration-200 hover:scale-105"
               style="background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2);">
              Zobacz kursy →
            </a>
          </div>

          <!-- Stats bar -->
          <div class="reveal delay-4 grid grid-cols-2 sm:grid-cols-4 gap-4">
            {stats.map((s, i) => (
              <div class="text-center p-4 rounded-2xl" style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);">
                <div class="font-display font-800 text-3xl sm:text-4xl"
                     style="color: var(--color-yellow);"
                     data-counter={s.value}
                     data-suffix={s.suffix}>
                  0{s.suffix}
                </div>
                <div class="text-xs font-medium mt-1 uppercase tracking-wider"
                     style="color: rgba(255,255,255,0.55);">
                  {s.label}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Bottom road stripe -->
      <div class="absolute bottom-0 left-0 right-0 z-10 road-stripe opacity-60"></div>
    </section>

    <!-- ═══════════════════════════════════════ O SZKOLE ═══════════════════════════════════════ -->
    <section id="o-szkole" class="py-24 relative overflow-hidden speed-lines" style="background: var(--color-white);">
      <!-- Decorative sign shape -->
      <div class="absolute top-12 right-0 w-64 h-64 rounded-l-full opacity-5"
           style="background: var(--color-blue);"></div>

      <div class="container mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Left: image + badge -->
          <div class="reveal-left relative">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl"
                 style="background: var(--color-light);">
              <img
                src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=800&q=80"
                alt="Instruktor i kursant w samochodzie"
                class="w-full h-80 lg:h-96 object-cover"
              />
              <!-- Overlay badge -->
              <div class="absolute bottom-4 left-4 right-4 p-4 rounded-2xl"
                   style="background: rgba(21,32,58,0.9); backdrop-filter: blur(8px);">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
                       style="background: var(--color-yellow);">🏆</div>
                  <div>
                    <div class="font-display font-700 text-sm" style="color: #fff;">Certyfikowana szkoła jazdy</div>
                    <div class="text-xs mt-0.5" style="color: rgba(255,255,255,0.6);">Licencja MiR nr 2341/W/2012</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Floating stat -->
            <div class="absolute -top-6 -right-6 w-28 h-28 rounded-2xl flex flex-col items-center justify-center shadow-xl hidden md:flex"
                 style="background: var(--color-blue); transform: rotate(6deg);">
              <span class="font-display font-800 text-3xl" style="color: var(--color-yellow);">94%</span>
              <span class="text-xs font-600 text-center leading-tight mt-1 px-2" style="color: rgba(255,255,255,0.8);">zdawal-<br/>ność</span>
            </div>
          </div>

          <!-- Right: text -->
          <div class="reveal-right">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-600 uppercase tracking-wider mb-4"
                 style="background: rgba(29,78,216,0.08); color: var(--color-blue);">
              🚗 O nas
            </div>
            <h2 class="font-display font-800 text-4xl sm:text-5xl leading-tight mb-6"
                style="color: var(--color-dark);">
              Więcej niż<br />
              <span style="color: var(--color-blue);">szkoła jazdy</span>
            </h2>
            <p class="text-lg leading-relaxed mb-6" style="color: var(--color-dark-mid);">
              OSK Start działa w Warszawie od 2012 roku. Przez ponad dekadę przeprowadziliśmy
              przez egzamin ponad <strong>3 200 kursantów</strong> — z wynikiem zdawalności
              na poziomie <strong>94%</strong>, który bije średnią krajową (58%).
            </p>
            <p class="leading-relaxed mb-8" style="color: var(--color-gray);">
              Wierzymy, że dobra nauka jazdy to nie tylko technika — to budowanie pewności siebie
              za kierownicą. Dlatego każdy kursant dostaje własnego instruktora-mentora, małe
              grupy teorii i indywidualny plan jazd.
            </p>

            <!-- Features grid -->
            <div class="grid sm:grid-cols-2 gap-4">
              {features.map((f, i) => (
                <div class={`reveal delay-${i % 3 + 1} flex items-start gap-3 p-4 rounded-2xl card-lift`}
                     style="background: var(--color-light); border: 1px solid var(--color-gray-light);">
                  <span class="text-2xl flex-shrink-0">{f.icon}</span>
                  <div>
                    <div class="font-display font-700 text-sm mb-1" style="color: var(--color-dark);">{f.title}</div>
                    <div class="text-xs leading-relaxed" style="color: var(--color-gray);">{f.desc}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ KURSY ═══════════════════════════════════════ -->
    <section id="kursy" class="py-24 relative overflow-hidden clip-diagonal"
             style="background: var(--color-dark); padding-bottom: 8rem;">

      <!-- Road texture overlay -->
      <div class="absolute inset-0 opacity-10"
           style="background-image: repeating-linear-gradient(90deg, rgba(250,204,21,0.5) 0, rgba(250,204,21,0.5) 2px, transparent 2px, transparent 80px);"></div>

      <div class="container mx-auto px-4 sm:px-6 relative z-10">
        <div class="text-center mb-14">
          <div class="reveal inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-600 uppercase tracking-wider mb-4"
               style="background: rgba(250,204,21,0.15); color: var(--color-yellow);">
            📋 Oferta
          </div>
          <h2 class="reveal delay-1 font-display font-800 text-4xl sm:text-5xl mb-4" style="color: #fff;">
            Wybierz swój <span style="color: var(--color-yellow);">kurs</span>
          </h2>
          <p class="reveal delay-2 text-lg max-w-xl mx-auto" style="color: rgba(255,255,255,0.6);">
            Mamy kurs dla każdego — niezależnie od tempa, budżetu i harmonogramu.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-6">
          {courses.map((c, i) => (
            <div class={`reveal delay-${i + 1} relative rounded-3xl overflow-hidden card-lift`}
                 style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">

              <!-- Top color bar -->
              <div class="h-1" style={`background: var(--color-${c.color === 'yellow' ? 'yellow' : c.color === 'red' ? 'red' : 'blue'});`}></div>

              <div class="p-6">
                <!-- Tag -->
                <div class="inline-flex px-2.5 py-1 rounded-full text-xs font-600 mb-4"
                     style={`background: rgba(${c.color === 'yellow' ? '250,204,21' : c.color === 'red' ? '239,68,68' : '29,78,216'},.15); color: var(--color-${c.color === 'yellow' ? 'yellow' : c.color === 'red' ? 'red' : 'blue'});`}>
                  {c.tag}
                </div>

                <div class="text-3xl mb-3">{c.icon}</div>
                <h3 class="font-display font-800 text-xl mb-1" style="color: #fff;">{c.title}</h3>
                <p class="text-xs font-600 mb-3 uppercase tracking-wide"
                   style={`color: var(--color-${c.color === 'yellow' ? 'yellow' : c.color === 'red' ? 'red' : 'blue'});`}>
                  {c.subtitle}
                </p>
                <p class="text-sm leading-relaxed mb-4" style="color: rgba(255,255,255,0.6);">{c.desc}</p>

                <ul class="space-y-2 mb-6">
                  {c.details.map(d => (
